<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Gambar Pokemon -->
        <ImageView
            android:id="@+id/imgPokemon"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_menu_gallery" />

        <!-- Info Pokemon (Nama & HP) -->
        <!-- layout_weight="1" membuat bagian ini mengambil sisa ruang yang ada -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/tvPokemonName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pikachu"
                android:textColor="#212121"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPokemonHp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HP: 120"
                android:textColor="#757575"
                android:textSize="14sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Tombol Hapus berada di paling kanan karena weight di atas -->
        <Button
            android:id="@+id/btnDeletePokemon"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hapus"
            android:textColor="#FF5252"
            app:strokeColor="#FF5252"
            android:textSize="12sp"
            android:paddingHorizontal="8dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>